#!/bin/zsh

set -eu

script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
repo_root=$(CDPATH= cd -- "$script_dir/.." && pwd)
index_name="llm-wiki"
config_dir="$repo_root/.qmd"
index_path="$config_dir/$index_name.sqlite"

mkdir -p "$config_dir"
cd "$repo_root"

exec env \
  QMD_CONFIG_DIR="$config_dir" \
  INDEX_PATH="$index_path" \
  qmd --index "$index_name" "$@"
